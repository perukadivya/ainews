# Environment Variables
# Get your Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Cron secret - used to protect manual trigger endpoints
CRON_SECRET=your_random_secret_here

# Database Configurations (Turso SQLite for Production)
# Get credentials from: https://turso.tech
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...

# Base URL (for production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Fallback AI Model (NVIDIA API)
# Get your key from https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
FALLBACK_MODEL=minimaxai/minimax-m2.7
